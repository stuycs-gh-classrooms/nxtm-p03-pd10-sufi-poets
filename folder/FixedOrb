class FixedOrb extends Orb
{

   /*
   Spawns the FixedOrb (earth) and colors it red.
   */
  FixedOrb(float x, float y, float s, float m)
  {
    super(x, y, s, m);
    c = color(255, 0, 0);
  }

  /**
   Overloads FixedOrb and colors it red.
   */
  FixedOrb()
  {
    super();
    c = color(255, 0, 0);
  }

  /**
   Forces the fixedOrb to stay in one place and do nothing if bounce/move is true.
   */
  void move(boolean bounce)
  {
    //do nothing
  }
}//fixedOrb
